# Firebase web app config (safe to expose in client builds — protected by Firestore rules).
# Copy this file to `.env.local` and fill in your project's values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "true" to point the app at the local Firebase Emulator Suite during dev.
VITE_USE_EMULATORS=false

# The OpenAI API key is NOT a client var. It is a Cloud Functions secret used by
# generateMeetingOutline. Set it (once) with:
#   firebase functions:secrets:set OPENAI_API_KEY
# Under the emulator / in tests no key is needed — the function returns a stub.
