# Firebase web app config (safe to expose in client builds — protected by Firestore rules).
# Copy this file to `.env.local` and fill in your project's values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "true" to point the app at the local Firebase Emulator Suite during dev.
VITE_USE_EMULATORS=false

# ---------------------------------------------------------------------------
# SERVER-SIDE env (the Vercel /api serverless functions). NOT client vars — set
# these in the Vercel project dashboard (Production + Preview), or in .env.local
# for local dev against a live backend. The Vite dev server picks them up from
# .env.local automatically. Under the emulator (dev:test / e2e) none are needed.
# ---------------------------------------------------------------------------
# OpenAI key for the meeting-outline generator (omit → authored fallback).
OPENAI_API_KEY=
# Firebase Admin service account (Project settings → Service accounts → Generate
# new private key). Used by /api to verify ID tokens and do privileged writes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal \n escapes from the JSON; the code restores real newlines.
FIREBASE_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Email (Resend) + Cron auth — server-side only. Set in Vercel project dashboard.
# ---------------------------------------------------------------------------
# Resend transactional email API key (resend.com → API Keys).
RESEND_API_KEY=
# Verified sender address configured in Resend (e.g. quizzes@yourdomain.com).
EMAIL_FROM=
# Random 32-byte hex secret used to sign HMAC unsubscribe tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_TOKEN_SECRET=
# Random secret Vercel injects as Authorization: Bearer <value> on every cron invocation.
# Generate the same way as EMAIL_TOKEN_SECRET.
CRON_SECRET=
# Optional: override the base URL used in unsubscribe links (defaults to VERCEL_URL which
# Vercel sets automatically). Set only if your canonical domain differs, e.g.:
#   APP_URL=https://app.yourdomain.com
APP_URL=
