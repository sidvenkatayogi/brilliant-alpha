# Test mode (`vite --mode test`) — overrides .env.local. Points at the local
# Emulator Suite using a `demo-` project, which needs no real credentials.
VITE_FIREBASE_API_KEY=demo-key
VITE_FIREBASE_AUTH_DOMAIN=demo-long-run.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-long-run
VITE_FIREBASE_STORAGE_BUCKET=demo-long-run.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:demo
VITE_FIREBASE_MEASUREMENT_ID=
VITE_USE_EMULATORS=true
