rules_version = '2';

// A learner can read and write ONLY their own user document and its subcollections.
// Lesson content is static in the bundle and never touches Firestore.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
