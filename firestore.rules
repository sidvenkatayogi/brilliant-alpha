rules_version = '2';

// Phase 1: a learner reads/writes ONLY their own user doc + subcollections.
// Phase 2 adds a scoped cohort layer: peers can read each other's THIN
// projection + shared meeting data, but never private progress. Membership
// (cohorts/{cid}.memberUids) is written only by the Admin SDK in a Cloud
// Function — clients are denied.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Email delivery records: read-own only; client writes denied (Admin SDK only).
      match /emailDelivery/{dateId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // no write allow -> denied (Admin SDK bypasses rules)
      }

      // Preserve existing broad access for all other subcollections.
      // Write guard explicitly excludes emailDelivery so the OR of all matching
      // rules does not re-grant writes that the emailDelivery block above omits.
      match /{subcol}/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId
                     && subcol != 'emailDelivery';
      }
    }

    match /cohorts/{cid} {
      // A member of the cohort can read its metadata.
      function isMember() {
        return request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/cohorts/$(cid)).data.memberUids;
      }

      allow read: if request.auth != null && request.auth.uid in resource.data.memberUids;
      // Membership changes only via the Admin SDK (assignCohort function).
      allow write: if false;

      // The thin peer-visible projection. Readable by any cohort member;
      // writable only by its owner (and only if they're a member).
      match /memberProgress/{uid} {
        allow read: if isMember();
        allow create, update: if request.auth != null
          && request.auth.uid == uid
          && isMember();
      }

      // Weekly meeting doc. Any member can create (race-safe by weekId id),
      // read, and update (confirm a slot, paste a link, store the AI outline).
      match /meetings/{wid} {
        allow read, create, update: if isMember();

        // Each member's own availability picks.
        match /availability/{uid} {
          allow read: if isMember();
          allow create, update: if request.auth != null
            && request.auth.uid == uid
            && isMember();
        }

        // The quiz answer key lives here. Clients are denied entirely — the
        // answers are released only by the getQuizAnswerKey Cloud Function
        // (Admin SDK), and only once the meeting time has arrived.
        match /private/{doc} {
          allow read, write: if false;
        }
      }
    }
  }
}
