{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2021",
    "lib": ["es2021"],
    "moduleResolution": "node",
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src"],
  "exclude": ["lib", "node_modules", "src/**/*.test.ts"]
}
