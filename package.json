{
  "name": "long-run",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && tsc -p tsconfig.api.json && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "firebase emulators:exec --only firestore --project demo-long-run \"vitest run --config vitest.integration.config.ts\"",
    "test:e2e": "playwright test",
    "emulators": "firebase emulators:start --only auth,firestore --project demo-long-run",
    "dev:test": "vite --mode test",
    "seed:demo": "node scripts/seed-demo.cjs",
    "seed:prod": "SEED_PROD=1 node scripts/seed-demo.cjs",
    "deploy:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "firebase": "^10.12.2",
    "firebase-admin": "^12.6.0",
    "framer-motion": "^12.42.0",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^3.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
