{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/cohort.ts": { "maxDuration": 60 },
    "api/email-unsubscribe.ts": { "maxDuration": 60 },
    "api/email-quiz.ts": { "maxDuration": 300 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [{ "path": "/api/email-quiz", "schedule": "0 7 * * *" }]
}
